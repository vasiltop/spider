FROM node:20-alpine AS build
WORKDIR /app

COPY pnpm-lock.yaml ./
COPY web/package.json ./web/
COPY web/ ./web/

ARG VITE_API_URL
ENV VITE_API_URL=$VITE_API_URL

RUN cd web && npm install --legacy-peer-deps && npm run build

FROM nginx:alpine
COPY --from=build /app/web/dist /usr/share/nginx/html
EXPOSE 80
